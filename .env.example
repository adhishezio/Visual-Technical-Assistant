# Copy this file to .env for local development.
# Keep real credentials only in .env or your runtime environment.

APP_NAME=Visual Technical Assistant API
ENVIRONMENT=local
DEBUG=false

# Keep Chroma as the default local vector store. Flip to "vertex" only for smoke tests or demos.
VECTOR_STORE=chroma
EMBEDDING_PROVIDER=vertex
EMBEDDING_MODEL=text-embedding-005
EMBEDDING_DIMENSION=768
CHROMA_PERSIST_DIRECTORY=db
CHROMA_COLLECTION_NAME=component_documentation
CHROMA_DISTANCE_METRIC=cosine
CHROMA_ANONYMIZED_TELEMETRY=false
ONNXRUNTIME_LOG_SEVERITY_LEVEL=4

VISION_PROVIDER=gemini
OCR_PROVIDER=trocr
IDENTIFICATION_CONFIDENCE_THRESHOLD=0.6
PART_NUMBER_CONFIDENCE_THRESHOLD=0.75

# Gemini and other general-purpose Google services.
GOOGLE_CLOUD_PROJECT=your-gemini-project-id
GOOGLE_CLOUD_LOCATION=us-central1
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.5-flash

# Vertex AI embeddings + Vector Search.
VERTEX_PROJECT_ID=your-vertex-project-id
VERTEX_AI_LOCATION=us-central1
VERTEX_INDEX_ENDPOINT_ID=projects/YOUR_VERTEX_PROJECT/locations/us-central1/indexEndpoints/YOUR_ID
VERTEX_DEPLOYED_INDEX_ID=component_docs_v1

# Firestore metadata store for Vertex Vector Search.
FIRESTORE_COLLECTION=component_chunks
FIRESTORE_PROJECT_ID=your-vertex-project-id

TROCR_MODEL=microsoft/trocr-large-printed
TROCR_DEVICE=
TROCR_MAX_NEW_TOKENS=64

SEARCH_PROVIDER=tavily
TAVILY_API_KEY=your-tavily-api-key
TAVILY_MAX_RESULTS=5

HTTP_TIMEOUT_SECONDS=20
DOCUMENT_CHUNK_SIZE=1200
DOCUMENT_CHUNK_OVERLAP=200
MAX_FETCH_ATTEMPTS=2
SIMILARITY_SEARCH_K=4

